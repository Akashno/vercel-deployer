# ─────────────────────────────────────────────────────────────────────────────
# PROJECTS — the one place all Vercel / GitHub / Jira config lives.
#
# A JSON array; add as many projects as you want (one entry = one project).
# Each entry:
#   id       (required)  unique slug used in the dashboard URL
#   name     (optional)  display name shown in the project switcher (defaults to id)
#   vercel   (required)  { token, projectId, teamId? }   teamId only if the project is in a Vercel team
#   github   (optional)  { token, owner, repo }          enables force-deploy + PR cards
#   jira     (optional)  { org, email, apiToken }         enables Jira ticket links
#
# Must be valid JSON on a SINGLE line (most .env parsers stop at the first newline).
# Prefer compact JSON; a trailing comma before ] or } is tolerated.
# ─────────────────────────────────────────────────────────────────────────────
PROJECTS=[{"id":"main-app","name":"Main App","vercel":{"token":"vcp_...","projectId":"prj_...","teamId":""},"github":{"token":"github_pat_...","owner":"acme","repo":"main-app"},"jira":{"org":"acme","email":"bot@acme.com","apiToken":"..."}}]

# Dashboard login (primary admin)
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET=

# Team members (comma-separated email:password pairs)
# Example: TEAM_MEMBERS="alex@company.com:pass123,qa@company.com:pass456"
TEAM_MEMBERS=
